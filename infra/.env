# Proton Pass vault references — no plaintext secrets.
# Run via:
#   pass-cli run --env-file=infra/.env -- ./infra/scripts/dagger-deploy.sh
#   pass-cli run --env-file=infra/.env -- ./infra/scripts/dagger-plan.sh
#   pass-cli run --env-file=infra/.env -- ./infra/scripts/start-smallweb-mutagen-sync.sh
#
# Adjust vault/item names to match your Proton Pass setup.
# Syntax: {{ op://VaultName/ItemTitle/fieldName }}

# ---------- secrets (Proton Pass vault references) ----------
CLOUDFLARE_API_TOKEN={{ op://Tidelane/Cloudflare/api_token }}
SSH_PUBLIC_KEY={{ op://Tidelane/SSH-tidelane/public_key }}
SSH_PRIVATE_KEY={{ op://Tidelane/SSH-tidelane/private_key }}
GCP_CREDENTIALS_JSON={{ op://Tidelane/GCP-service-account/credential_file }}
OPENROUTER_API_KEY={{ op://Tidelane/OpenRouter/api_key }}

# ---------- non-secret config (edit directly) ----------
BACKEND_BUCKET=my-tf-state-bucket
BACKEND_PREFIX=tidelands-dev/{slot}/terraform.tfstate
GCP_PROJECT=my-gcp-project-id
CLOUDFLARE_ZONE_ID=abc123def456
DEPLOYMENT_SLOT=green
ADMIN_AUTHORIZED_EMAILS=
DOMAIN=tidelands.dev
