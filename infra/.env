# Proton Pass secret references — no plaintext secrets.
# Run via:
#   ./infra/scripts/dagger.sh plan
#   ./infra/scripts/dagger.sh deploy
#   pass-cli run --env-file=infra/.env -- ./infra/scripts/start-smallweb-mutagen-sync.sh
#
# Adjust vault/item names to match your Proton Pass setup.
# Syntax: pass://VaultName/ItemTitle/fieldName

# ---------- secrets (Proton Pass vault references) ----------
CLOUDFLARE_API_TOKEN=pass://tidelands.dev/CLOUDFLARE_API_TOKEN/API%20Key
SSH_PUBLIC_KEY=pass://tidelands.dev/SSH-tidelane/public_key
SSH_PRIVATE_KEY=pass://tidelands.dev/SSH-tidelane/private_key
GCP_CREDENTIALS_JSON=pass://tidelands.dev/GCP_CREDENTIALS_JSON/note
OPENROUTER_API_KEY=pass://tidelands.dev/OPENROUTER_API_KEY/API%20Key

# ---------- non-secret config (edit directly) ----------
BACKEND_BUCKET=my-tf-state-bucket
BACKEND_PREFIX=tidelands-dev/{slot}/terraform.tfstate
GCP_PROJECT=my-gcp-project-id
CLOUDFLARE_ZONE_ID=abc123def456
DEPLOYMENT_SLOT=green
ADMIN_AUTHORIZED_EMAILS=
DOMAIN=tidelands.dev
