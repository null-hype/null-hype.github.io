  {
    name: 'dotfiles',
    desc: 'Curated shell config, Neovim setup, and dev-env bootstrap scripts.',
    lang: 'Shell',
    color: '#89e051',
    stars: 56,
    forks: 9,
  },
  {
    name: 'til',
    desc: 'Today I Learned — a running log of small discoveries and snippets.',
    lang: 'Markdown',
    color: '#083fa1',
    stars: 21,
    forks: 3,
  },
  {
    name: 'advent-of-code',
    desc: 'AoC puzzle solutions, mostly TypeScript with the occasional Rust.',
    lang: 'TypeScript',
    color: '#3178c6',
    stars: 8,
    forks: 1,
  },
];

const feed = [
  { icon: '⬆', label: 'push',   repo: 'null-hype/linear-agent',         text: 'Pushed 3 commits to main',                   time: '2 hours ago' },
  { icon: '⤴', label: 'pr',     repo: 'null-hype/obsidian-daily',        text: 'Opened PR #18 — Add weekly rollup view',      time: 'yesterday' },
  { icon: '✓', label: 'issue',  repo: 'null-hype/dotfiles',              text: 'Closed issue #4 — zsh startup regression',    time: '2 days ago' },
  { icon: '★', label: 'star',   repo: 'vitejs/vite',                     text: 'Starred vitejs/vite',                         time: '3 days ago' },
  { icon: '⬆', label: 'push',   repo: 'null-hype/null-hype.github.io',   text: 'Pushed 7 commits to master',                 time: '4 days ago' },
  { icon: '⎇', label: 'fork',   repo: 'sindresorhus/awesome',            text: 'Forked sindresorhus/awesome',                 time: '5 days ago' },
  { icon: '⬆', label: 'push',   repo: 'null-hype/til',                   text: 'Pushed 1 commit to main',                    time: '1 week ago' },
  { icon: '!', label: 'issue',  repo: 'null-hype/advent-of-code',        text: 'Opened issue #2 — Day 12 part 2 perf',       time: '1 week ago' },
