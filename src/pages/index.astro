        </div>
      </section>

      <!-- ── CONTRIBUTION GRAPH ──────────────────────────────── -->
      <section class="contrib-section">
        <header class="section-heading-row">
          <h2 class="section-heading">
            {totalContributions.toLocaleString()} contributions in the last year
          </h2>
        </header>
        <div class="contrib-box">
          <div class="contrib-graph" style={`--weeks: ${weeks.length}`}>
            <!-- Month labels -->
            <div class="month-row">
              {monthLabels.map(m => (
                <span class="month-label" style={`grid-column: ${m.col + 1}`}>{m.label}</span>
              ))}
            </div>
            <!-- Day grid -->
            <div class="day-grid">
              {weeks.map((week) =>
                week.map((day) => (
                  <div
                    class={`day ${level(day.count)}`}
                    title={`${day.count} contribution${day.count !== 1 ? 's' : ''} on ${day.date}`}
                  ></div>
