</BaseLayout>

<style>
  /* ── Layout ─────────────────────────────────────────────────── */
  .profile-layout {
    display: grid;
    grid-template-columns: 296px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── Sidebar ─────────────────────────────────────────────────── */
  .sidebar {
    position: sticky;
    top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .avatar-wrap { width: 100%; }

  .avatar {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #21262d;
  }

  .avatar svg { width: 100%; height: 100%; display: block; }

  .identity { margin-top: 0.5rem; }

  .display-name {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text);
  }

  .username {
    font-size: 1.1rem;
    color: var(--muted);
    margin: 0.15rem 0 0;
    font-weight: 300;
  }

  .bio {
    font-size: 0.9rem;
    color: var(--text);
    margin: 0;
    line-height: 1.6;
  }

  .follow-btn {
    display: block;
    width: 100%;
    padding: 0.3rem 0.75rem;
    text-align: center;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: #21262d;
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .follow-btn:hover { background: #30363d; border-color: #8b949e; }

  .stat-row {
    display: flex;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    flex-wrap: wrap;
  }
  .stat-row strong { color: var(--text); font-weight: 600; }
  .stat-row span   { color: var(--muted); }

  .meta-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--muted);
  }
  .meta-list li { display: flex; align-items: center; gap: 0.5rem; }
  .meta-list a  { color: var(--text); text-decoration: none; }
  .meta-list a:hover { color: var(--accent); text-decoration: underline; }

  .meta-icon {
    width: 1rem;
    height: 1rem;
    fill: var(--muted);
    flex-shrink: 0;
  }

  .sidebar-heading {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .org-list {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .org-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    background: #21262d;
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--muted);
    cursor: pointer;
  }
  .org-avatar:hover { border-color: var(--accent); color: var(--accent); }

  /* ── Tabs ─────────────────────────────────────────────────────── */
  .profile-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--line);
    margin-bottom: 1.25rem;
    overflow-x: auto;
  }

  .tab {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .tab:hover   { color: var(--text); }
  .tab.active  { color: var(--text); border-bottom-color: var(--accent); font-weight: 600; }

  .tab-count {
    display: inline-flex;
    align-items: center;
    padding: 0 0.4rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
  }

  /* ── README ──────────────────────────────────────────────────── */
  .readme-box {
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }

  .readme-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--line);
    font-size: 0.875rem;
    color: var(--muted);
  }

  .readme-icon {
    width: 1rem; height: 1rem;
    fill: var(--muted);
  }

  .readme-filename { color: var(--muted); }
  .readme-filename strong { color: var(--text); }

  .readme-body {
    padding: 1.25rem 1.5rem;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text);
  }

  .readme-title {
