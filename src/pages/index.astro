import BaseLayout from '../layouts/BaseLayout.astro';

// Deterministic pseudo-random so the graph doesn't flicker on hot-reload
function seededRand(seed: number): number {
  const x = Math.sin(seed + 9301) * 49297;
  return x - Math.floor(x);
}

// Build ~53 weeks of contribution data ending today
const today = new Date('2026-03-23');
const weeks: Array<Array<{ date: string; count: number }>> = [];

for (let w = 52; w >= 0; w--) {
  const days: Array<{ date: string; count: number }> = [];
  for (let d = 6; d >= 0; d--) {
    const date = new Date(today);
    date.setDate(today.getDate() - (w * 7 + d));
    const seed = w * 7 + d;
    const r = seededRand(seed);
    const isWeekend = date.getDay() === 0 || date.getDay() === 6;
    const active = r > (isWeekend ? 0.55 : 0.30);
    const count = active ? Math.floor(seededRand(seed + 1000) * 14) + 1 : 0;
    days.push({ date: date.toISOString().split('T')[0], count });
  }
  weeks.push(days);
}

const totalContributions = weeks.flat().reduce((s, d) => s + d.count, 0);

function level(count: number): string {
  if (count === 0) return 'l0';
  if (count < 3)  return 'l1';
  if (count < 7)  return 'l2';
  if (count < 11) return 'l3';
  return 'l4';
}

// Month labels: find first week of each month
const monthLabels: Array<{ label: string; col: number }> = [];
let lastMonth = -1;
weeks.forEach((week, wi) => {
  const m = new Date(week[0].date).getMonth();
  if (m !== lastMonth) {
    monthLabels.push({
      label: new Date(week[0].date).toLocaleString('en-US', { month: 'short' }),
      col: wi,
    });
    lastMonth = m;
  }
});

const pinnedRepos = [
