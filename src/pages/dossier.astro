---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/editorial.css';
import AnalystCallout from '../components/AnalystCallout';
import ArchiveEntry from '../components/ArchiveEntry';
import CaseNode from '../components/CaseNode';
import EpistemicFrame from '../components/EpistemicFrame';
import EvidenceCard from '../components/EvidenceCard';
import InlineFigure from '../components/InlineFigure';
import PullQuote from '../components/PullQuote';
import SectionBreak from '../components/SectionBreak';
import WatchlistPanel from '../components/WatchlistPanel';
import {
	analystCalloutContent,
	archiveEntries,
	caseNodes,
	caseSectionContent,
	comparisonNotes,
	evidenceCards,
	epistemicFrameContent,
	footerLinks,
	inlineFigureContent,
	leadParagraphs,
	pullQuoteContent,
	sectionBreakContent,
	sideRailItems,
	synthesisContent,
	topNavItems,
	watchlistContent,
} from '../data/editorialContent';
---

<BaseLayout
	title="jungle.roaring.wave | PLAN-26 v3.5 dossier"
	description="PLAN-26 v3.5 rendered as an editorial dossier using the Storybook component library."
>
	<div class="editorial-page">
		<div class="editorial-grain" aria-hidden="true"></div>

		<header class="editorial-topbar">
			<div class="editorial-topbar__inner">
				<div class="editorial-topbar__group">
					<a class="editorial-topbar__brand" href="/now">jungle.roaring.wave</a>
					<nav class="editorial-nav" aria-label="Primary dossier sections">
						{
							topNavItems.map((item) => (
								<a href={item.href} class:list={{ 'is-active': Boolean(item.active) }}>
									{item.label}
								</a>
							))
						}
					</nav>
				</div>

				<div class="editorial-topbar__actions">
					<a class="editorial-pdf-link" href="/now">Now page</a>
				</div>
			</div>
		</header>

		<aside class="editorial-sidebar" aria-label="Dossier shortcuts">
			<div class="editorial-sidebar__inner">
				<div class="editorial-sidebar__brand">
					<span class="editorial-sidebar__brand-mark">JRW</span>
					<span class="editorial-sidebar__ref">Ref: PLAN-26 v3.5</span>
				</div>

				<nav class="editorial-sidebar__nav" aria-label="Section shortcuts">
					{
						sideRailItems.map((item) => (
							<a href={item.href} class:list={{ 'is-active': Boolean(item.active) }}>
								<span class="editorial-sidebar__icon material-symbols-outlined" aria-hidden="true">
									{item.icon}
								</span>
								<span>{item.label}</span>
							</a>
						))
					}
				</nav>
			</div>
		</aside>

		<main class="editorial-main">
			<section id="epistemic" class="editorial-section editorial-section--bordered">
				<div class="editorial-container">
					<EpistemicFrame {...epistemicFrameContent} />
				</div>
			</section>

			<div class="editorial-block">
				<div class="editorial-container">
					<InlineFigure {...inlineFigureContent} />
				</div>
			</div>

			<div class="editorial-block editorial-block--tight">
				<div class="editorial-container editorial-prose editorial-prose--lead">
					{leadParagraphs.map((paragraph) => <p>{paragraph}</p>)}
				</div>
			</div>

			<section id="cases" class="editorial-section">
				<div class="editorial-container">
					<header class="editorial-section-heading">
						<h2 class="editorial-section-heading__title">{caseSectionContent.title}</h2>
						<p class="editorial-section-heading__eyebrow">{caseSectionContent.eyebrow}</p>
					</header>

					<div class="editorial-prose editorial-prose--case-intro">
						{caseSectionContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
					</div>

					<div class="editorial-case-stack">
						<CaseNode {...caseNodes[0]} />
						<PullQuote {...pullQuoteContent} />
						<CaseNode {...caseNodes[1]} />
						<div class="evidence-grid">
							{evidenceCards.map((card) => <EvidenceCard {...card} />)}
						</div>
						<AnalystCallout {...analystCalloutContent} />
						<CaseNode {...caseNodes[2]} />
						<CaseNode {...caseNodes[3]} />
					</div>
				</div>
			</section>

			<div id="comparisons" class="editorial-section-break-wrap">
				<div class="editorial-container">
					<SectionBreak {...sectionBreakContent} />
				</div>
			</div>

			<section class="editorial-section archive-section">
				<div class="editorial-container archive-section__grid">
					<div class="archive-section__intro">
						<h2 class="archive-section__title">Comparative Baselines</h2>
						<p class="archive-section__eyebrow">Historical precedent, red-team warning, forecast layer.</p>
						<div class="archive-section__copy">
							<p>
								A sequence like this only becomes durable if it survives comparison. That means
								looking for both historical forms that make it more plausible and warning labels that
								make overreach easier to spot.
							</p>
							<p>
								The goal is not to flatten everything into one chain. The goal is to locate where the
								argument gains traction, where it starts flattering itself, and where it can be forced
								into real questions.
							</p>
						</div>
					</div>
					<div class="archive-section__list">
						{archiveEntries.map((entry) => <ArchiveEntry {...entry} />)}
					</div>
				</div>
			</section>

			<section class="editorial-section editorial-section--bordered">
				<div class="editorial-container editorial-note-stack">
					{
						comparisonNotes.map((note) => (
							<article id={note.id} class="editorial-note">
								<h3 class="editorial-note__title">{note.title}</h3>
								<div class="editorial-note__copy">
									{note.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
								</div>
							</article>
						))
					}
				</div>
			</section>

			<section id="forecast" class="editorial-section">
				<div class="editorial-container synthesis-section__grid">
					<div class="synthesis-section__copy">
						<h2 class="synthesis-section__title">{synthesisContent.title}</h2>
						<div class="synthesis-copy">
							{synthesisContent.paragraphs.map((paragraph, index) => <p class:list={{ 'is-muted': index === synthesisContent.paragraphs.length - 1 }}>{paragraph}</p>)}
						</div>
					</div>
					<div class="synthesis-section__panel">
						<WatchlistPanel {...watchlistContent} />
					</div>
				</div>
			</section>
		</main>

		<footer class="editorial-footer">
			<div class="editorial-container editorial-footer__grid">
				<div class="editorial-footer__copy">
					<span class="editorial-footer__brand">jungle.roaring.wave</span>
					<p class="editorial-footer__meta">PLAN-26 v3.5 rendered March 24, 2026.</p>
					<p class="editorial-footer__legal">
						This version treats the sequence as a candidate signal that must survive comparison,
						counterargument, and future scoring before it earns anything stronger than disciplined
						suspicion.
					</p>
				</div>

				<div class="editorial-footer__links">
					{
						footerLinks.map((link) => (
							<a href={link.href}>
								{link.label}
							</a>
						))
					}
				</div>
			</div>
		</footer>
	</div>
</BaseLayout>
