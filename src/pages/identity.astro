---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/editorial.css';
import EpistemicFrame from '../components/EpistemicFrame';
import ArchiveEntry from '../components/ArchiveEntry';
import { identityDossierContent } from '../data/identityDossier';

const { masthead, reference, headline, about, experience, projects, skills, languages } = identityDossierContent;

const epistemicProps = {
	eyebrow: reference,
	title: headline,
	flags: [
		{ label: 'Security Research', tone: 'signal' as const },
		{ label: 'Platform Engineering', tone: 'accent' as const },
		{ label: 'Agentic Systems', tone: 'muted' as const },
	],
	boundaryLabel: 'Identity Boundaries // What I Do Not Do',
	boundaries: [
		'Not looking for traditional web developer roles.',
		'Not interested in standard TPM positions.',
	],
	thesis: about[0],
	paragraphs: about.slice(1),
	annexLabel: 'View Current Priorities',
	annexHref: '/now',
};
---

<BaseLayout
	title={`Identity Sync | ${masthead}`}
	description={headline}
>
	<div class="editorial-page">
		<div class="editorial-grain" aria-hidden="true"></div>

		<header class="editorial-topbar">
			<div class="editorial-topbar__inner">
				<div class="editorial-topbar__group">
					<a class="editorial-topbar__brand" href="/now">jungle.roaring.wave</a>
					<nav class="editorial-nav">
						<a href="/now">Now</a>
						<a href="/dossier">Dossier</a>
						<a href="/identity" class="is-active">Identity</a>
					</nav>
				</div>
			</div>
		</header>

		<main class="editorial-main">
			<section class="editorial-section editorial-section--bordered">
				<div class="editorial-container">
					<EpistemicFrame {...epistemicProps} />
				</div>
			</section>

			<section class="editorial-section">
				<div class="editorial-container archive-section__grid">
					<div class="archive-section__intro">
						<h2 class="archive-section__title">Professional Experience</h2>
						<p class="archive-section__eyebrow">Technical work, market signals, and scale.</p>
					</div>
					<div class="archive-section__list">
						{experience.map((exp, i) => (
							<ArchiveEntry
								index={`EXP_0${i + 1}`}
								title={exp.role}
								intent={exp.period}
								summary={exp.description || (exp.bullets ? exp.bullets.join(' // ') : '')}
								latestHeadline={exp.company || exp.location || 'Freelance'}
								href="#"
							/>
						))}
					</div>
				</div>
			</section>

			<section class="editorial-section">
				<div class="editorial-container archive-section__grid">
					<div class="archive-section__intro">
						<h2 class="archive-section__title">Key Projects</h2>
						<p class="archive-section__eyebrow">Automated infrastructure & offensive research.</p>
					</div>
					<div class="archive-section__list">
						{projects.map((proj, i) => (
							<ArchiveEntry
								index={`PROJ_0${i + 1}`}
								title={proj.title}
								intent={proj.subtitle}
								summary={proj.description}
								latestHeadline="Active Development"
								href="#"
							/>
						))}
					</div>
				</div>
			</section>

			<section class="editorial-section editorial-section--bordered">
				<div class="editorial-container">
					<h2 class="font-display text-4xl mb-8 uppercase tracking-tighter">Skills & Languages</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
						<div>
							<h3 class="font-label text-xs uppercase mb-4 opacity-50">Technical Stack</h3>
							<div class="flex flex-wrap gap-2">
								{skills.add.map(skill => (
									<span class="px-3 py-1 bg-white/10 text-[10px] font-bold uppercase tracking-widest">{skill}</span>
								))}
							</div>
						</div>
						<div>
							<h3 class="font-label text-xs uppercase mb-4 opacity-50">Languages</h3>
							<div class="flex flex-wrap gap-4">
								{languages.map(lang => (
									<div class="flex flex-col">
										<span class="font-display text-2xl tracking-tighter uppercase">{lang.name}</span>
										<span class="font-label text-[10px] opacity-50 uppercase">{lang.level}</span>
									</div>
								))}
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>

		<footer class="editorial-footer">
			<div class="editorial-container">
				<p class="editorial-footer__meta">Ref: {reference} // Identity Sync Completed March 24, 2026</p>
			</div>
		</footer>
	</div>
</BaseLayout>

<style>
	.grid { display: grid; }
	.grid-cols-1 { grid-template-columns: 1fr; }
	@media (min-width: 768px) {
		.grid-cols-2 { grid-template-columns: 1fr 1fr; }
	}
	.gap-12 { gap: 3rem; }
	.gap-2 { gap: 0.5rem; }
	.gap-4 { gap: 1rem; }
	.mb-8 { margin-bottom: 2rem; }
	.mb-4 { margin-bottom: 1rem; }
	.flex { display: flex; }
	.flex-wrap { flex-wrap: wrap; }
	.flex-col { flex-direction: column; }
	.px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
	.py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
	.bg-white\/10 { background-color: rgba(255, 255, 255, 0.1); }
	.text-xs { font-size: 0.75rem; }
	.text-4xl { font-size: 2.25rem; line-height: 2.5rem; }
	.text-\[10px\] { font-size: 10px; }
	.font-display { font-family: 'Newsreader', serif; }
	.font-label { font-family: 'Inter', sans-serif; }
	.tracking-tighter { letter-spacing: -0.05em; }
	.tracking-widest { letter-spacing: 0.1em; }
	.uppercase { text-transform: uppercase; }
	.opacity-50 { opacity: 0.5; }
</style>
