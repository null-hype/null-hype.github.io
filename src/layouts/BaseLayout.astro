---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'null hype',
	description = 'Plain Astro site for null hype.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<style is:global>
			:root {
				color-scheme: dark;
				--bg: #09090b;
				--bg-muted: rgba(255, 255, 255, 0.04);
				--panel: rgba(20, 20, 25, 0.72);
				--text: #f5f5f5;
				--muted: #a1a1aa;
				--line: rgba(255, 255, 255, 0.1);
				--accent: #f97316;
				--accent-soft: rgba(249, 115, 22, 0.16);
				font-family: "IBM Plex Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				min-height: 100%;
				background:
					radial-gradient(circle at top, rgba(249, 115, 22, 0.24), transparent 36%),
					linear-gradient(180deg, #111114 0%, var(--bg) 42%, #050507 100%);
				color: var(--text);
			}

			body {
				line-height: 1.5;
			}

			a {
				color: inherit;
			}

			main {
				padding: 4rem 1.5rem 5rem;
			}

			.shell {
				margin: 0 auto;
				width: min(72rem, 100%);
			}

			.hero {
				display: grid;
				gap: 2rem;
				padding: 2rem 0 3rem;
				border-bottom: 1px solid var(--line);
			}

			.kicker {
				margin: 0 0 0.75rem;
				color: var(--accent);
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			h1,
			h2 {
				margin: 0;
				font-weight: 700;
				line-height: 0.96;
				letter-spacing: -0.04em;
			}

			h1 {
				max-width: 12ch;
				font-size: clamp(3.5rem, 11vw, 7.5rem);
			}

			h2 {
				font-size: clamp(1.5rem, 4vw, 2.4rem);
			}

			.lede,
			.copy {
				max-width: 42rem;
				margin: 0;
				color: var(--muted);
				font-size: clamp(1.05rem, 2vw, 1.25rem);
			}

			.summary {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
				gap: 1rem;
				margin-top: 1.5rem;
			}

			.card {
				padding: 1.25rem;
				border: 1px solid var(--line);
				border-radius: 1.25rem;
				background: var(--panel);
				backdrop-filter: blur(18px);
			}

			.card strong {
				display: block;
				margin-bottom: 0.5rem;
				font-size: 1.05rem;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
				gap: 1rem;
				margin-top: 2.5rem;
			}

			.section {
				padding-top: 2.5rem;
			}

			.section-header {
				display: grid;
				gap: 0.75rem;
				margin-bottom: 1.5rem;
			}

			.label {
				display: inline-flex;
				width: fit-content;
				padding: 0.3rem 0.65rem;
				border-radius: 999px;
				background: var(--accent-soft);
				color: #fdba74;
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.list {
				margin: 0;
				padding-left: 1.1rem;
				color: var(--muted);
			}

			.list li + li {
				margin-top: 0.55rem;
			}

			.footer {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--line);
				color: var(--muted);
				font-size: 0.95rem;
			}

			@media (max-width: 720px) {
				main {
					padding-top: 3rem;
				}

				.hero {
					padding-top: 0.5rem;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<div class="shell">
				<slot />
			</div>
		</main>
	</body>
</html>
