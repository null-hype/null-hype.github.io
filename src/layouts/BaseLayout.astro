---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'null hype',
	description = 'Plain Astro site for null hype.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<style is:global>
			:root {
				color-scheme: dark;
				--bg: #0d1117;
				--text: #e6edf3;
				--muted: #8b949e;
				--line: #30363d;
				--accent: #f78166;
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans",
					Helvetica, Arial, sans-serif;
			}

			* { box-sizing: border-box; }

			html, body {
				margin: 0;
				min-height: 100%;
				background: var(--bg);
				color: var(--text);
				line-height: 1.5;
			}

			a { color: inherit; }

			/* Top nav bar (decorative) */
			body::before {
				content: '';
				display: block;
				height: 48px;
				background: #161b22;
				border-bottom: 1px solid var(--line);
			}

			main {
				padding: 1.5rem;
				max-width: 1280px;
				margin: 0 auto;
			}

			@media (max-width: 480px) {
				main { padding: 1rem 0.75rem; }
			}
		</style>
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>
