---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowPageView from './NowPageView';
import {
	createUnavailableNowPageData,
	getNowPageDataFromCollections,
} from '../data/nowPageData';
import '../styles/editorial.css';
import '../styles/now-page.css';

let pageData = createUnavailableNowPageData();

try {
	pageData = await getNowPageDataFromCollections();
} catch (error) {
	const detail = error instanceof Error ? error.message : 'Unknown Linear content error';
	pageData = {
		...createUnavailableNowPageData(),
		warning: `Unable to load the Planning-team publishing view. ${detail}`,
	};
}
---

<BaseLayout
	title="tidelands.dev | Projects"
	description="Planning-team project index derived from the Linear `www` view."
>
	<NowPageView
		client:load
		meta={pageData.meta}
		sections={pageData.sections}
		warning={pageData.warning}
		isFavorited={pageData.isFavorited}
	/>
</BaseLayout>
