---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowPageView from './NowPageView';
import '../styles/editorial.css';
import '../styles/now-page.css';
import { getNowPageDataFromCollections } from '../data/nowPageData';

const pageData = await getNowPageDataFromCollections();
---

<BaseLayout
	title={pageData.meta.title}
	description={pageData.meta.footer}
>
	<NowPageView meta={pageData.meta} sections={pageData.sections} isFavorited={pageData.isFavorited} />
</BaseLayout>
