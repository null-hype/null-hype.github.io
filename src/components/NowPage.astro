---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowPageView from './NowPageView';
import '../styles/editorial.css';
import '../styles/now-page.css';
import { createUnavailableNowPageData, getLinearNowPageData } from '../data/linearNowPage';
import { getCollection } from 'astro:content';
import { generateTidelaneNodes } from '../data/tidelane';

const NOW_PAGE_TIDELANE_SEED = 26;
const tidelaneNodes = generateTidelaneNodes(NOW_PAGE_TIDELANE_SEED);
const projectNodes = tidelaneNodes.filter(node => node.phase.name === 'full');

let pageData = createUnavailableNowPageData();
let warning: string | undefined;

try {
	pageData = await getLinearNowPageData();
} catch (error) {
	warning =
		'Linear data is unavailable for this build. Confirm LINEAR_API_KEY and outbound access to api.linear.app.';

	if (import.meta.env.DEV) {
		console.error('Failed to load Linear now page data.', error);
	}
}

const projectEntries = await getCollection('projects');
const issueEntries = await getCollection('issues');
const activeProjects = projectEntries.filter(p => p.data?.Status === 'In Progress');

// Map projects to TidelaneListSection
if (activeProjects.length > 0) {
    const projectSection = {
        id: 'projects',
        title: 'Projects',
        summary: `Tracking ${activeProjects.length} active initiatives from local content collections.`,
        items: activeProjects.map((project, index) => {
            // Find the first issue that belongs to this project
            // Projects and Issues might share Project ID or just Project Name
            const projectIssues = issueEntries.filter(issue => 
                issue.data.Project === project.data.Name || 
                issue.data["Project ID"] === project.data.ID
            );
            
            const href = `/projects/${project.id}`;

            return {
                title: project.data.Name,
                body: project.data.Summary || project.data.Description || '',
                references: `Project: ${project.data.ID} / ${project.data.Status}${projectIssues.length > 0 ? ` / ${projectIssues.length} issues` : ''}`,
                href,
                lane: {
                    slug: projectNodes[index % projectNodes.length].slug,
                    w3w: projectNodes[index % projectNodes.length].w3w,
                    moon: projectNodes[index % projectNodes.length].moon,
                    phase: projectNodes[index % projectNodes.length].phase,
                }
            };
        })
    };
    pageData = {
        ...pageData,
        meta: {
            ...pageData.meta,
            intro: [],
        },
        sections: [projectSection]
    };
}
---

<BaseLayout
	title="jungle.roaring.wave | Now"
	description="What Richard Anthony is focused on now, pulled from current assigned Linear issues."
>
	<NowPageView meta={pageData.meta} sections={pageData.sections} warning={warning} />
</BaseLayout>
