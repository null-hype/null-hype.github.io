module OpenTraderSecurityRules

class SecurityRule {
  name: String
  predicate: String
  message: String
}

authGroundedInUserControllableInput = new SecurityRule {
  name = "auth_grounded_in_user_controllable_input"
  predicate = "authorization.subject == request.body.user_id"
  message = "auth grounded in user-controllable input"
}
