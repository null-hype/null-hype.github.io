<style is:global>
  /* Reserve space for the fixed footer band */
  body {
    padding-bottom: 28px !important;
  }

  #gap-footer-band {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 28px;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    font-size: 11px;
    font-family: Inter, system-ui, sans-serif;
    background-color: var(--tk-background-secondary, #f6f8f9);
    border-top: 1px solid var(--tk-elements-app-borderColor, #e4e6e9);
    color: var(--tk-text-secondary, #6b7280);
    padding: 0 16px;
  }

  [data-theme='dark'] #gap-footer-band {
    background-color: var(--tk-background-secondary, #2b2d35);
    border-color: rgba(255, 255, 255, 0.08);
    color: rgba(255,255,255,0.45);
  }

  #gap-footer-band a {
    color: inherit;
    text-decoration: none;
    opacity: 0.8;
  }

  #gap-footer-band a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  #gap-footer-band .gap-footer-sep {
    opacity: 0.3;
  }
</style>

<script is:inline>
  (function injectFooter() {
    if (document.getElementById('gap-footer-band')) return;
    var footer = document.createElement('div');
    footer.id = 'gap-footer-band';
    footer.innerHTML = [
      '<span>Robin Jordan</span>',
      '<span class="gap-footer-sep">·</span>',
      // TODO: replace href with live article URL once PLAN-326 publishes on tidelands.dev
      '<a href="https://github.com/null-hype/null-hype.github.io" target="_blank" rel="noopener">Grammar as Protocol</a>',
      '<span class="gap-footer-sep">·</span>',
      '<a href="https://github.com/null-hype" target="_blank" rel="noopener">GitHub</a>',
    ].join('');
    if (document.body) {
      document.body.appendChild(footer);
    } else {
      document.addEventListener('DOMContentLoaded', function() {
        document.body.appendChild(footer);
      });
    }
  })();
</script>

<script is:inline src="/coi-serviceworker.js"></script>

