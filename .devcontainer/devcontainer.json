{
  "name": "null-hype.github.io",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "mounts": [
    "source=null-hype-devcontainer-gcloud,target=/home/vscode/.config/gcloud,type=volume",
    "source=null-hype-devcontainer-mutagen,target=/home/vscode/.mutagen,type=volume",
    "source=null-hype-devcontainer-terraform,target=/home/vscode/.terraform.d,type=volume",
    "source=null-hype-devcontainer-ssh,target=/home/vscode/.ssh,type=volume"
  ],
  "overrideFeatureInstallOrder": [
    "ghcr.io/devcontainers/features/docker-in-docker",
    "./features/src/operator-tools",
    "ghcr.io/devcontainers/features/sshd"
  ],
  "features": {
    "./features/src/operator-tools": {
      "terraformVersion": "1.7.5",
      "daggerVersion": "0.13.7",
      "mutagenVersion": "0.18.1",
      "denoVersion": "v2.7.1",
      "smallwebVersion": "0.28.4",
      "installGcloud": true
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [
    4321
  ],
  "secrets": {
    "ANTHROPIC_API_KEY": {
      "description": "Anthropic API key for Claude Code inside the devcontainer."
    },
    "LINEAR_API_KEY": {
      "description": "Linear API key used by the Linear MCP server."
    },
    "GITHUB_PERSONAL_ACCESS_TOKEN": {
      "description": "GitHub personal access token used by the GitHub MCP server."
    }
  },
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "LINEAR_API_KEY": "${localEnv:LINEAR_API_KEY}",
    "GITHUB_PERSONAL_ACCESS_TOKEN": "${localEnv:GITHUB_PERSONAL_ACCESS_TOKEN}",
    "CLOUDSDK_CONFIG": "/home/vscode/.config/gcloud",
    "TF_PLUGIN_CACHE_DIR": "/home/vscode/.terraform.d/plugin-cache"
  },
  "portsAttributes": {
    "4321": {
      "label": "astro"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "anthropic.claude-code",
        "GitHub.codespaces",
        "CodeSandbox-io.codesandbox-projects"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "sudo mkdir -p /run/sshd && (sudo service ssh start || sudo /usr/sbin/sshd)"
}
